# Titans - API Key Configuration
# Copy this file to .env and fill in the keys for the providers you want to use.
# The app works with any subset of keys; unavailable agents are shown with a status message.

# OpenAI (GPT-4) — Neural Memory Module agent
OPENAI_API_KEY=sk-...

# Anthropic (Claude) — Memory as Context agent
ANTHROPIC_API_KEY=sk-ant-...

# Mistral — Memory as Gate agent
MISTRAL_API_KEY=...

# Groq — Memory as Layer agent
GROQ_API_KEY=...

# Google Gemini — Experimental Validation agent
GOOGLE_API_KEY=...

# Cohere — Innovations agent
COHERE_API_KEY=...

# Emergence — Analysis agent
EMERGENCE_API_KEY=...
